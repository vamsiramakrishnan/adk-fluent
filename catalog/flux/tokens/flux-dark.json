  "space": {
    "0":   "0px",
    "0_5": "2px",
    "1":   "4px",
    "1_5": "6px",
    "2":   "8px",
    "3":   "12px",
    "4":   "16px",
    "5":   "20px",
    "6":   "24px",
    "8":   "32px",
    "10":  "40px",
    "12":  "48px",
    "16":  "64px",
    "20":  "80px",
    "24":  "96px"
  },
  "radius": {
    "none": "0px",
    "xs":   "2px",
    "sm":   "4px",
    "md":   "6px",
    "lg":   "10px",
    "xl":   "14px",
    "2xl":  "20px",
    "full": "9999px"
  },
  "shadow": {
    "none":  "none",
    "sm":    "0 1px 2px rgba(0,0,0,0.4)",
    "md":    "0 2px 8px rgba(0,0,0,0.5)",
    "lg":    "0 8px 24px rgba(0,0,0,0.6)",
    "xl":    "0 16px 48px rgba(0,0,0,0.7)",
    "focus": "0 0 0 3px rgba(139,92,246,0.45)"
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "200ms",
      "slow": "320ms"
    },
    "easing": {
      "standard":   "cubic-bezier(0.2, 0, 0, 1)",
      "emphasized": "cubic-bezier(0.3, 0, 0, 1)",
      "decelerate": "cubic-bezier(0, 0, 0, 1)"
    }
  },
  "typography": {
    "family": {
      "sans": "ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
      "mono": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace"
    },
    "size": {
      "xs":  "12px",
      "sm":  "14px",
      "md":  "16px",
      "lg":  "18px",
      "xl":  "20px",
      "2xl": "24px",
      "3xl": "30px",
      "4xl": "36px",
      "5xl": "48px"
    },
    "weight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },
    "lineHeight": {
      "tight":   1.2,
      "normal":  1.5,
      "relaxed": 1.75
    }
  },
  "z": {
    "base":     0,
    "dropdown": 1000,
    "sticky":   1100,
    "overlay":  1200,
    "modal":    1300,
    "toast":    1400
  }
