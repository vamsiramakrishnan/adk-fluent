{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adk-fluent.dev/flux/schema/component.schema.json",
  "title": "flux Component Definition",
  "description": "One compiled flux component as emitted into catalog.json. Authored as a .spec.ts via the flux DSL.",
  "type": "object",
  "required": ["name", "extends", "category", "jsonSchema", "tokens", "accessibility", "llm", "renderer"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^Flux[A-Z][A-Za-z0-9]+$",
      "description": "Catalog-id. MUST be prefixed with 'Flux' to avoid colliding with basic-catalog names."
    },
    "extends": {
      "type": "string",
      "description": "Basic-catalog component this flux component refines. Used to derive the fallback block.",
      "enum": [
        "Text", "Image", "Icon", "Video", "AudioPlayer",
        "Row", "Column", "List", "Card", "Tabs", "Modal", "Divider",
        "Button", "TextField", "CheckBox", "ChoicePicker", "Slider", "DateTimeInput"
      ]
    },
    "category": {
      "enum": ["primitive", "compound", "intent"],
      "description": "Layer classification; see ARCHITECTURE.md section 3."
    },
    "jsonSchema": {
      "type": "object",
      "description": "JSON Schema describing this component's props. Compiled from the Zod schema in the DSL. MUST declare { component: const <name> }."
    },
    "slots": {
      "type": "object",
      "description": "Named insertion points. Keys are slot names.",
      "additionalProperties": {
        "type": "object",
        "required": ["kind"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ],
            "description": "Accepted child kind(s). A2UI basic or flux component name(s)."
          },
          "required":   { "type": "boolean", "default": false },
          "max":        { "type": "integer", "minimum": 1 }
        }
      }
    },
    "variants": {
      "type": "object",
      "description": "Variant recipe. Each key is a dimension (e.g. 'tone'); each value is a map of variant-name to style object with token refs.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      }
    },
    "compoundVariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["style"],
        "properties": {
          "style": {
            "type": "object",
            "additionalProperties": { "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }] }
          }
        },
        "additionalProperties": { "type": "string" }
      }
    },
    "defaultVariants": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "tokens": {
      "type": "array",
      "description": "All token paths this component references. Build fails if any path is missing from the active token pack.",
      "items": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_]*(\\.[a-zA-Z0-9_]+)*$" },
      "uniqueItems": true
    },
    "accessibility": {
      "type": "object",
      "required": ["label"],
      "additionalProperties": false,
      "properties": {
        "label":    { "enum": ["required", "optional", "none"] },
        "role":     { "type": "string" },
        "keyboard": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "action"],
            "additionalProperties": false,
            "properties": {
              "key":    { "type": "string" },
              "action": { "type": "string" }
            }
          }
        }
      }
    },
    "llm": {
      "type": "object",
      "required": ["description", "examples", "budget"],
      "additionalProperties": false,
      "properties": {
        "description":  { "type": "string", "minLength": 1 },
        "tags":         { "type": "array", "items": { "type": "string" } },
        "examples": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["code", "caption"],
            "additionalProperties": false,
            "properties": {
              "code":    { "type": "string" },
              "caption": { "type": "string" }
            }
          }
        },
        "antiPatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "reason"],
            "additionalProperties": false,
            "properties": {
              "code":   { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
        "budget": {
          "type": "object",
          "required": ["children", "siblings"],
          "additionalProperties": false,
          "properties": {
            "children": { "type": "integer", "minimum": 0 },
            "siblings": { "type": "integer", "minimum": 0 },
            "depth":    { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "renderer": {
      "type": "object",
      "required": ["react", "fallback"],
      "additionalProperties": false,
      "properties": {
        "react":   { "type": "string", "description": "Repo-relative path to the React component file." },
        "fallback": {
          "type": "object",
          "required": ["component"],
          "additionalProperties": false,
          "properties": {
            "component": { "type": "string" },
            "map": {
              "type": "object",
              "description": "Prop-renaming map (flux-prop to basic-prop).",
              "additionalProperties": { "type": "string" }
            },
            "notes": { "type": "string" }
          }
        }
      }
    }
  }
}
